{
  "name": "holyrics-to-vmix",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "control-panel"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace control-panel run dev --host\"",
    "dev:server": "npm --workspace server run dev",
    "dev:panel": "npm --workspace control-panel run dev",
    "build": "npm --workspace control-panel run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}